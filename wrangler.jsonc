{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "omnichannel-commerce-crm",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-16",
	"vars": {
		"ENVIRONMENT": "development",
	},
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
	"compatibility_flags": [ "nodejs_compat" ]
}
