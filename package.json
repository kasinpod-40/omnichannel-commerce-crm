{
  "name": "omnichannel-commerce-crm",
  "version": "1.6.5",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:run",
    "test:run": "npm run test:unit && npm run test:integration",
    "check": "npm run typecheck && npm run test:run && npm run deploy:dry",
    "cf-typegen": "wrangler types",
    "test:unit": "npm run test:unit:node && npm run test:unit:worker",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:unit:node": "vitest run --config vitest.config.mts",
    "test:unit:worker": "vitest run --config vitest.worker-unit.config.mts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@types/node": "^25.9.3",
    "typescript": "^5.5.2",
    "vitest": "~4.1.9",
    "wrangler": "^4.105.0"
  }
}
